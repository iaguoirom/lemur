# %% [markdown]
# # 動画クリッピングツール
#
# 動画の指定区間を切り出して保存する（再エンコードなし）。
#
# - 入力：動画ファイルのパス・開始時刻・終了時刻
# - 出力：clips フォルダに保存

# %%
import cv2
import os
from pathlib import Path

OUTPUT_DIR = r'F:\thesis\clips'
Path(OUTPUT_DIR).mkdir(parents=True, exist_ok=True)
print(f'保存先: {OUTPUT_DIR}')

# %% [markdown]
# ## 切り出す動画と時間を指定する

# %%
# ここを書き換えて実行する
# ----------------------------------------------------
VIDEO_PATH = r"F:\ワオキツネザルCAM1\20250427AM\ワオキツネザルCAM1-20250427-085828-1745711908801-7.mp4"

START = '00:18:50'   # 切り出し開始時刻（時:分:秒）
END   = '00:19:20'   # 切り出し終了時刻（時:分:秒）
# ----------------------------------------------------

def time_to_sec(t):
    """'HH:MM:SS' または 'MM:SS' を秒数に変換"""
    parts = t.strip().split(':')
    parts = [int(p) for p in parts]
    if len(parts) == 3:
        return parts[0]*3600 + parts[1]*60 + parts[2]
    elif len(parts) == 2:
        return parts[0]*60 + parts[1]
    else:
        return int(parts[0])

start_sec = time_to_sec(START)
end_sec   = time_to_sec(END)

# 動画の情報を確認
cap = cv2.VideoCapture(VIDEO_PATH)
if not cap.isOpened():
    print(f'動画を開けませんでした: {VIDEO_PATH}')
else:
    fps         = cap.get(cv2.CAP_PROP_FPS)
    total_frames= int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    total_sec   = total_frames / fps
    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    cap.release()

    print(f'ファイル  : {os.path.basename(VIDEO_PATH)}')
    print(f'解像度    : {w}x{h}')
    print(f'FPS       : {fps:.1f}')
    print(f'総再生時間: {int(total_sec//60):02d}:{int(total_sec%60):02d} ({total_sec:.1f}秒)')
    print(f'切り出し  : {START} → {END}  ({end_sec - start_sec}秒間)')

    if end_sec > total_sec:
        print(f'終了時刻({END})が動画の長さを超えています')
    if start_sec >= end_sec:
        print('開始時刻が終了時刻より後になっています')

# %% [markdown]
# ## 切り出し実行

# %%
# 出力ファイル名を自動生成（元のファイル名_開始_終了.mp4）
stem     = Path(VIDEO_PATH).stem
out_name = f"{stem}_{START.replace(':','-')}_{END.replace(':','-')}.mp4"
out_path = str(Path(OUTPUT_DIR) / out_name)

# 切り出し実行
cap = cv2.VideoCapture(VIDEO_PATH)
fourcc = cv2.VideoWriter_fourcc(*'mp4v')
out    = cv2.VideoWriter(out_path, fourcc, fps, (w, h))

start_frame = int(start_sec * fps)
end_frame   = int(end_sec   * fps)

cap.set(cv2.CAP_PROP_POS_FRAMES, start_frame)

frame_count = 0
for i in range(end_frame - start_frame):
    ret, frame = cap.read()
    if not ret:
        break
    out.write(frame)
    frame_count += 1

cap.release()
out.release()

print(f'保存先: {out_path}')
print(f'フレーム数: {frame_count} ({frame_count/fps:.1f}秒)')


