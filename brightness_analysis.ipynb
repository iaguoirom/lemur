# %% [markdown]
# OpenCVを用いた輝度検知

# %% [markdown]
# 動画の各フレームから平均輝度を取り出して時系列データにする。 
# 
# 輝度が急に落ちた瞬間 ＝雲が太陽を遮った瞬間、として記録する。
# 
# これにより、1時間単位の気温・風速データでは捉えられない秒単位のミクロな環境変化を動画から直接取得できる。

# %% [markdown]
# ライブラリとパス設定
# 
# １．ライブラリ
# cv2 OpenCV　動画を開いてフレームを取り出すのに使う
# 
# numpy ピクセル値の平均計算
# 
# pandas 時系列データの整理とCSV出力
# 
# matplotlib 輝度グラフの可視化
# 
# ２．フレームレートが15fpsなので、1秒に1回つまり15フレームに1回サンプリングすることとする。
# 
# DROP‗THRESHOULDは調整可能、輝度が0(真っ黒)～255(真っ白)なので
# 

# %%
import cv2
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from pathlib import Path

CSV_PATH = r"F:\thesis\filtered_videos_final.csv"
OUTPUT_DIR = r"F:\thesis\brightness"
Path(OUTPUT_DIR).mkdir(exist_ok=True)

SAMPLE_INTERVAL = 15      # 15フレームに1回（＝1秒に1ポイント）
DROP_THRESHOLD  = -15     # 輝度がこれ以上急落したらイベントとして記録

# %% [markdown]
# 動画を開いてOpenCvに読ませる

# %%
df = pd.read_csv(CSV_PATH)
row = df.iloc[0]  # 最初の1本だけ

video_path = str(Path(row['folder']) / row['filename'])
print(f"対象動画: {video_path}")

cap = cv2.VideoCapture(video_path)
if not cap.isOpened():
    print("❌ 動画を開けませんでした")
else:
    print("✅ 動画を開けました")
    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    fps = cap.get(cv2.CAP_PROP_FPS)
    print(f"総フレーム数: {total_frames}, FPS: {fps:.1f}, 長さ: {total_frames/fps/60:.1f}分")

# %% [markdown]
# 輝度の計算

# %%
brightness_records = []
frame_idx = 0

while True:
    ret, frame = cap.read()
    if not ret:
        break
    if frame_idx % SAMPLE_INTERVAL == 0:
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        mean_brightness = float(np.mean(gray))
        timestamp_sec = frame_idx / fps
        brightness_records.append({
            'frame'    : frame_idx,
            'time_sec' : timestamp_sec,
            'time_str' : f"{int(timestamp_sec//60):02d}:{int(timestamp_sec%60):02d}",
            'brightness': mean_brightness,
        })
    frame_idx += 1

cap.release()

bright_df = pd.DataFrame(brightness_records)
bright_df['diff'] = bright_df['brightness'].diff()
bright_df['event'] = bright_df['diff'] < DROP_THRESHOLD

print(f"✅ 取得ポイント数: {len(bright_df)}")
print(f"輝度急落イベント数: {bright_df['event'].sum()}")
print(bright_df[bright_df['event']][['time_str','brightness','diff']].to_string())

# %%
fig, ax = plt.subplots(figsize=(14, 4))
ax.plot(bright_df['time_sec'], bright_df['brightness'], color='steelblue', linewidth=0.8)

# イベントを赤い縦線で表示
events = bright_df[bright_df['event']]
for _, ev in events.iterrows():
    ax.axvline(ev['time_sec'], color='red', alpha=0.7, linewidth=1.2)

ax.set_xlabel("時刻（秒）")
ax.set_ylabel("平均輝度")
ax.set_title(f"輝度時系列：{row['filename']}")
plt.tight_layout()
plt.savefig(str(Path(OUTPUT_DIR) / "test_brightness.png"), dpi=150)
plt.show()
print("✅ グラフ保存完了")


